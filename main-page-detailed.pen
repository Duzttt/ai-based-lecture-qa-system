// Detailed .pen file representing the main page layout of Lecture Note QA System
// Based on the Vue.js frontend structure

// Main application frame (full window)
appFrame=I(document, {type: "frame", layout: "vertical", width: 1280, height: 720, fill: "#1E293B"})

// Top bar - contains app title, user info, and action buttons
topBar=I(appFrame, {type: "frame", layout: "horizontal", width: "fill_container", height: 60, fill: "#0F172A"})
// Top bar content would include:
// - App title/logo on left
// - User profile/actions on right

// Main content area (horizontal split) - takes remaining vertical space
mainContent=I(appFrame, {type: "frame", layout: "horizontal", width: "fill_container", height: "fill_container"})

// Left panel - SourcesPanel (fixed width)
// Shows list of uploaded documents with selection capabilities
sourcesPanel=I(mainContent, {type: "frame", layout: "vertical", width: 260, height: "fill_container", fill: "#0F172A"})
// SourcesPanel internal structure:
// - Header: "Sources" label
// - Search/filter box
// - Document list with checkboxes
// - Action buttons (upload, refresh, etc.)
// - Selected documents counter

// Center panel - Main content area (flexible width)
// Contains either ChatPanel (default) or ComparisonView (when comparing docs)
centerPanel=I(mainContent, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", fill: "#1E293B"})

// ChatPanel - Default view in center panel
chatPanel=I(centerPanel, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", fill: "#1E293B"})
// ChatPanel internal structure:
// - Chat messages area (scrollable)
// - Input field with send button
// - Suggested questions chip list
// - Loading indicators
// - Message actions (copy, cite, etc.)

// ComparisonView - Alternative view in center panel (toggled when comparing docs)
// Would replace ChatPanel when comparison mode is active
comparisonView=I(centerPanel, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", fill: "#1E293B"})
// ComparisonView internal structure:
// - Side-by-side document chunks
// - Similarity highlighting
// - Difference analysis
// - Navigation controls

// Right panel - StudioPanel (fixed width)
// Contains AI tools and operations
studioPanel=I(mainContent, {type: "frame", layout: "vertical", width: 270, height: "fill_container", fill: "#0F172A"})
// StudioPanel internal structure:
// - Embedding model selector dropdown
// - Studio tools grid (Summary, Quiz, Flashcards, Podcast)
// - Summary viewer/modal
// - Model comparison tool
// - Status and progress indicators

// Modal overlays (positioned absolutely in actual implementation)
// SettingsModal - appears over main content when settings button clicked
settingsModal=I(document, {type: "frame", layout: "vertical", width: 500, height: 400, fill: "#1E293B"})
// SettingsModal content:
// - LLM provider selection (Gemini/OpenRouter/Ollama)
// - Model selection and API key input
// - RAG configuration (chunk size, top-k, etc.)
// - Embedding model management
// - Save/Cancel buttons

// AdminDashboard - appears over main content when admin button clicked
adminModal=I(document, {type: "frame", layout: "vertical", width: 800, height: 600, fill: "#1E293B"})
// AdminDashboard content:
// - Statistics and metrics panels
// - Query analytics
// - Document management
// - System health indicators
// - Configuration management

// Additional component representations for completeness:
// These would be internal to the main panels above

// Topbar internal elements
topBarTitle=I(topBar, {type: "text", content: "LectureNote QA", fill: "#E5E7EB", fontSize: 18})
topBarUser=I(topBar, {type: "text", content: "User ▼", fill: "#9CA3AF", fontSize: 14})

// SourcesPanel internal elements
sourcesHeader=I(sourcesPanel, {type: "text", content: "Sources", fill: "#E5E7EB", fontSize: 16, y: 10})
sourcesSearch=I(sourcesPanel, {type: "frame", layout: "horizontal", width: "fill_container", height: 30, fill: "#374151", y: 40})
sourcesList=I(sourcesPanel, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", y: 80})

// ChatPanel internal elements
chatMessages=I(chatPanel, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", y: 10})
chatInput=I(chatPanel, {type: "frame", layout: "horizontal", width: "fill_container", height: 50, fill: "#374151"})

// StudioPanel internal elements
studioHeader=I(studioPanel, {type: "text", content: "Studio", fill: "#E5E7EB", fontSize: 16, y: 10})
studioModelSelector=I(studioPanel, {type: "frame", layout: "vertical", width: "fill_container", height: 40, y: 40})
studioToolsGrid=I(studioPanel, {type: "frame", layout: "grid", width: "fill_container", height: 200, y: 90})
studioSummaryViewer=I(studioPanel, {type: "frame", layout: "vertical", width: "fill_container", height: "fill_container", y: 300})
