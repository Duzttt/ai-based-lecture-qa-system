            "body": {
              "mode": "raw",
              "raw": "{\n  \"llm_model\": \"{{llmModel}}\",\n  \"top_k\": {{topK}},\n  \"temperature\": 0.7\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rag-config/update",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "rag-config",
                "update"
              ]
            }
          }
        }
      ]
    },
