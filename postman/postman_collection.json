        {
          "name": "Switch to Gemini (Keep Existing API Key)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"gemini\",\n  \"model\": \"gemini-2.5-flash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "settings"
              ]
            },
            "description": "Safe default request. It does not send api_key, so an existing stored key is preserved."
          }
        },
        {
          "name": "Switch to llama.cpp",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"local_llm\",\n  \"model\": \"{{llmModel}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "settings"
              ]
            }
          }
        },
        {
          "name": "Get RAG Config",
