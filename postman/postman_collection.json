{
  "info": {
    "name": "RAG Lecture Q&A API",
    "description": "Postman collection for the RAG Lecture Note Q&A System.\n\nNotes:\n- Change {{baseUrl}} if the API is not running on localhost:8000.\n- Several requests store IDs back into collection variables for later requests.\n- The provider switch requests are safe by default and do not overwrite stored API keys.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "llmProvider",
      "value": "local_llm"
    },
    {
      "key": "llmModel",
      "value": "qwen2.5:3b"
    },
    {
      "key": "topK",
      "value": "5"
    },
    {
      "key": "documentName",
      "value": "YOUR_FILE.pdf"
    },
    {
      "key": "secondDocumentName",
      "value": "SECOND_FILE.pdf"
    },
    {
      "key": "queryText",
      "value": "What are the key concepts covered in the lecture?"
    },
    {
      "key": "suggestionQuestion",
      "value": "What is machine learning?"
    },
    {
      "key": "conversationId",
      "value": ""
    },
    {
      "key": "historyId",
      "value": ""
    },
    {
      "key": "summaryLimit",
      "value": "10"
    },
    {
      "key": "logsPageSize",
      "value": "20"
    }
  ],
  "item": [
    {
      "name": "Health & Discovery",
      "item": [
        {
          "name": "API Root",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('API root reports running status', function () {",
                  "  pm.expect(data.status).to.eql('running');",
                  "  pm.expect(data.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api"
              ]
            }
          }
        },
        {
          "name": "LLM Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('LLM health response includes status', function () {",
                  "  pm.expect(['healthy', 'disconnected', 'stalled']).to.include(data.status);",
                  "  pm.expect(data.provider).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health/llm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "llm"
              ]
            }
          }
        }
      ]
    },
