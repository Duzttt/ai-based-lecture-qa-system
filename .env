# Google Gemini API Key
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Change model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openrouter/free

# LLM Provider: "gemini", "openrouter", or "local_qwen"
LLM_PROVIDER=openrouter

# Disable OneDNN for TensorFlow
TF_ENABLE_ONEDNN_OPTS=0

# Upload indexing strategy
UPLOAD_INDEXING_STRATEGY=append
